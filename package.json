{
  "name": "compaction-analyzer-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vue-tsc --noEmit && vite build",
    "test": "vitest run",
    "bench:alive": "tsx scripts/bench-alive.mjs",
    "bench:process": "tsx scripts/bench-process.mjs",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.1",
    "@vitejs/plugin-vue": "^5.2.3",
    "tsx": "^4.22.4",
    "typescript": "~5.7.0",
    "vite": "^6.3.2",
    "vitest": "^4.1.8",
    "vue-tsc": "^2.2.8",
    "wrangler": "^4.99.0"
  }
}
